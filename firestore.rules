rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the request belongs to the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profiles: Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Q&A / Community: Anyone can read, but only authenticated users can create
    match /community_qa/{questionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Only the author can update or delete their question
      allow update, delete: if isOwner(resource.data.authorId);
    }

    // Public Content (e.g., Courses or Quran Metadata): Read-only for everyone
    match /content/{document=**} {
      allow read: if true;
      allow write: if false; // Only manageable via Admin SDK/Console
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}